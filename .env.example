# Configuration de l'application AléoConnect
# Copier ce fichier en .env.development ou .env.production et ajuster les valeurs

# Développement : laisser vide, les requêtes passent par le proxy Vite (même origine)
# Production    : OBLIGATOIRE — URL complète du backend (front et back peuvent être sur des hôtes distincts)
#                 Exemple : VITE_API_BASE_URL=https://api.aleoconnect.fr
VITE_API_BASE_URL=

# URL du backend local pour le proxy Vite (dev uniquement)
VITE_BACKEND_URL=http://localhost:8080
